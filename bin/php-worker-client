#!/usr/bin/env php
<?php

declare(strict_types=1);

$autoload = null;
$dir = __DIR__;
for ($i = 0; $i < 6; $i++) {
    $candidate = $dir . '/autoload.php';
    if (is_file($candidate)) {
        $autoload = $candidate;
        break;
    }
    $dir = dirname($dir);
}

if ($autoload !== null) {
    require_once $autoload;
} else {
    require_once __DIR__ . '/../src/VHttpd/PhpWorker/Client.php';
}

function arg(array $argv, string $key, string $default): string
{
    for ($i = 1; $i < count($argv); $i++) {
        if ($argv[$i] === $key && isset($argv[$i + 1])) {
            return (string) $argv[$i + 1];
        }
        if (str_starts_with((string) $argv[$i], $key . '=')) {
            return substr((string) $argv[$i], strlen($key) + 1);
        }
    }
    return $default;
}

$argv = $_SERVER['argv'] ?? [];
$socket = arg($argv, '--socket', '/tmp/vphp_worker.sock');
$method = strtoupper(arg($argv, '--method', 'GET'));
$path = arg($argv, '--path', '/health');
$body = arg($argv, '--body', '');

$request = [
    'id' => 'cli-1',
    'method' => $method,
    'path' => $path,
    'query' => [],
    'headers' => [],
    'body' => $body,
];

try {
    $client = new \VPhp\VHttpd\PhpWorker\Client($socket);
    $response = $client->request($request);
    echo json_encode($response, JSON_UNESCAPED_UNICODE) . PHP_EOL;
} catch (Throwable $e) {
    fwrite(STDERR, $e->getMessage() . PHP_EOL);
    exit(1);
}
